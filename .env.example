# Copy this file to `.env` and fill in any value tagged REQUIRED.
# `.env` is gitignored — never commit real keys.

# -------- App / logging --------
# OPTIONAL — application port. Default 8080. The TA expects 8080.
APP_PORT=8080
# OPTIONAL — INFO by default. DEBUG enables verbose tracing.
LOG_LEVEL=INFO

# -------- Neo4j (graph store) --------
# Inside docker-compose the app reaches Neo4j over the private network.
# Locally (without Docker) you can override NEO4J_URI to bolt://localhost:7687.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# REQUIRED — set a strong password locally. The compose file uses this same value
# to bootstrap the Neo4j container, so changing it here is the only step needed.
NEO4J_PASSWORD=instagent123
NEO4J_DATABASE=neo4j

# -------- Collection (Apify) --------
# Three modes:
#   fixture     — read fixtures/raw_artifacts.json (offline, used by tests)
#   apify_data  — read a previously-saved Apify export (no API call)
#   apify       — call the live Apify actor (requires APIFY_API_TOKEN)
COLLECTION_MODE=fixture
COLLECTION_FIXTURE_PATH=fixtures/raw_artifacts.json
APIFY_DATA_PATH=apify_data/dataset.json
APIFY_ACTOR_ID=apify/instagram-scraper
APIFY_API_TOKEN=
APIFY_MAX_ITEMS_PER_RUN=50

# -------- Extraction LLM (OpenAI-compatible endpoint) --------
EXTRACT_MODE=heuristic
EXTRACT_LLM_PROVIDER=openai
EXTRACT_LLM_MODEL=Qwen/Qwen3-8B
EXTRACT_LLM_BASE_URL=https://api.openai.com/v1
# REQUIRED ONLY IF EXTRACT_MODE=llm. Otherwise leave empty.
EXTRACT_LLM_API_KEY=
EXTRACT_LLM_TIMEOUT_SECONDS=60
EXTRACT_MAX_CONCURRENCY=4

# -------- Deduplication --------
DEDUP_EMBEDDING_BACKEND=char_ngram
DEDUP_FUZZY_MERGE_THRESHOLD=0.90
DEDUP_EMBEDDING_MERGE_THRESHOLD=0.82
DEDUP_FUZZY_REVIEW_THRESHOLD=0.78
DEDUP_CHAR_NGRAM_N=3

# -------- Quality gate (LLM-as-judge) --------
QUALITY_LLM_ENABLED=false
QUALITY_LLM_PROVIDER=openai
QUALITY_LLM_MODEL=Qwen/Qwen3-8B
QUALITY_LLM_BASE_URL=https://api.openai.com/v1
QUALITY_LLM_API_KEY=
QUALITY_LLM_SAMPLE_SIZE=10
QUALITY_LLM_MIN_SCORE_THRESHOLD=0.75
QUALITY_FAIL_ON_WARNING=false

# -------- Query (Graph-RAG) --------
# REQUIRED — the /api/query endpoint translates NL to Cypher with this LLM.
# US-03 (error path) intentionally leaves this blank to surface a 503.
QUERY_LLM_ENABLED=true
QUERY_LLM_PROVIDER=openai
QUERY_LLM_MODEL=Qwen/Qwen3-8B
QUERY_LLM_BASE_URL=https://api.openai.com/v1
QUERY_LLM_API_KEY=
QUERY_LLM_TIMEOUT_SECONDS=60
QUERY_MAX_LIMIT=50
QUERY_MAX_EVIDENCE_ROWS=20
