# Copy this file to `.env` and fill real credentials locally.
# `.env` is gitignored. Never commit secrets.

# -------- UTSA model endpoints (optional aliases used by the team) --------
UTSA_LLAMA_API_KEY=
UTSA_LLAMA_BASE_URL=
UTSA_LLAMA_MODEL=meta-llama/Llama-3.1-8B-Instruct

UTSA_QWEN_API_KEY=
UTSA_QWEN_BASE_URL=
UTSA_QWEN_MODEL=Qwen/Qwen3-8B

# -------- Quality gate --------
QUALITY_CHECK_MODE=llm_only
QUALITY_LLM_ENABLED=true
QUALITY_LLM_API_KEY=
QUALITY_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
QUALITY_LLM_BASE_URL=
QUALITY_LLM_SAMPLE_SIZE=10
QUALITY_LLM_MAX_CONCURRENCY=10
QUALITY_LLM_MIN_SCORE_THRESHOLD=0.75
# QUALITY_FAIL_ON_WARNING=true

# -------- Collection --------
# Modes:
#   fixture     -> fixtures/raw_artifacts.json
#   apify_data  -> offline JSON replay from APIFY_DATA_PATH
#   apify       -> live Apify actor call (costs credits)
COLLECTION_MODE=apify_data
APIFY_DATA_PATH=apify_data/input.json
APIFY_ACTOR_ID=apify/instagram-scraper
APIFY_MAX_ITEMS_PER_RUN=0

# -------- Extraction --------
EXTRACT_MODE=llm
EXTRACT_LLM_PROVIDER=openai
EXTRACT_LLM_MODEL=Qwen/Qwen3-8B
EXTRACT_LLM_BASE_URL=
EXTRACT_LLM_API_KEY=
EXTRACT_LLM_TIMEOUT_SECONDS=30
EXTRACT_MAX_CONCURRENCY=30
EXTRACTION_DB_PATH=data/extraction_records.db

# -------- Dedup --------
DEDUP_DB_PATH=data/dedup_reports.db
DEDUP_EMBEDDING_BACKEND=char_ngram
DEDUP_FUZZY_MERGE_THRESHOLD=0.90
DEDUP_EMBEDDING_MERGE_THRESHOLD=0.82
DEDUP_FUZZY_REVIEW_THRESHOLD=0.78
DEDUP_CHAR_NGRAM_N=3

# -------- Graph store --------
GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# -------- Query (Graph-RAG) --------
QUERY_LLM_ENABLED=true
QUERY_LLM_PROVIDER=openai
QUERY_LLM_MODEL=Qwen/Qwen3-8B
QUERY_LLM_BASE_URL=
QUERY_LLM_API_KEY=
QUERY_LLM_TIMEOUT_SECONDS=60
QUERY_MAX_LIMIT=50
QUERY_MAX_EVIDENCE_ROWS=20

# -------- Spec regeneration --------
ANTHROPIC_API_KEY=

# -------- App --------
LOG_LEVEL=INFO
MAX_CONTEXT_TOKENS=4000
APP_PORT=8080
