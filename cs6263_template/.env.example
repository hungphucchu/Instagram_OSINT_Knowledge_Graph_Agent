# Copy this file to .env and fill in the values marked REQUIRED.
# .env is gitignored. Never commit real keys.

# REQUIRED — Anthropic API key for spec regeneration and (optionally) the
# application generator. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# OPTIONAL — log level. INFO by default. DEBUG for verbose tracing.
LOG_LEVEL=INFO

# OPTIONAL — maximum context tokens passed to the LLM per request.
MAX_CONTEXT_TOKENS=4000

# OPTIONAL — application port. Default 8080. The TA expects 8080.
APP_PORT=8080
